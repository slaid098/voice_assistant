# Word to activate the assistant (lowercase)
WAKE_WORD=вики

# Comma-separated aliases for fuzzy matching (lowercase)
WAKE_ALIASES=вики,wiki,вика,ники,мики,фрики,вику,вике,викки

# Fuzzy match threshold (0-100, higher = stricter)
WAKE_THRESHOLD=70

# How long to wait for activation phrase (ms, 30000 = 30 sec)
WAKE_TIMEOUT_MS=30000

# How long to wait for a command (ms)
COMMAND_TIMEOUT_MS=6000

# Default city for weather
WEATHER_DEFAULT_CITY=Костюковка

# OpenWeather API key (https://openweathermap.org/api)
# Leave empty to use Open-Meteo (free, no registration needed)
OPENWEATHER_API_KEY=

# Number of YouTube search results
YOUTUBE_SEARCH_LIMIT=10
