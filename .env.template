# ── Голосовой помощник — настройки ───────────────────────────────────────
# Скопируйте этот файл в .env и измените при необходимости.
# Все настройки имеют значения по умолчанию — можно запускать без .env.

# ── Слово активации ──────────────────────────────────────────────────────
# Слово, которое включает ассистента (в нижнем регистре)
WAKE_WORD=вики

# Алиасы для нечёткого распознавания (через запятую, в нижнем регистре)
WAKE_ALIASES=вики,wiki,вика,ники,мики,фрики,вику,вике,викки

# Порог нечёткого матчинга слова активации (0-100, выше = строже)
WAKE_THRESHOLD=70

# ── Детектор слова активации ─────────────────────────────────────────────
# Способ распознавания слова активации: vosk | fuzzy
#   vosk  — локальная модель Vosk (грамматика + fuzzy-порог), мгновенно без
#           сети. Двойная защита от ложных срабатываний. Рекомендуется.
#   fuzzy — запись→Google→fuzzy-матчинг (требует интернет, медленнее).
#           Авто-fallback на fuzzy если Vosk-модель не загрузилась.
WAKE_WORD_DETECTOR=vosk

# ── STT (распознавание команд) ────────────────────────────────────────────
# Провайдер распознавания команд ПОСЛЕ слова активации: google | vosk | auto
#   google — онлайн, лучшее качество распознавания свободной речи (основной)
#   vosk   — офлайн, локальная модель (мгновенно, без интернета)
#   auto   — vosk основной, google резерв
STT_PROVIDER=google

# Язык распознавания Google STT (ru-RU, en-US, и т.д.)
STT_LANGUAGE=ru-RU

# ── Таймауты записи (миллисекунды) ───────────────────────────────────────
# Сколько ждать слово активации, прежде чем замолчать (30000 = 30 сек)
WAKE_TIMEOUT_MS=30000

# Сколько ждать команду после активации (мс)
COMMAND_TIMEOUT_MS=6000

# Максимум непониманий подряд, прежде чем вернуться в режим ожидания
MAX_MISUNDERSTAND=3

# ── Распознавание речи (VAD) ─────────────────────────────────────────────
# Частота дискретизации микрофона (Гц). 16000 — оптимально для STT
SAMPLERATE=16000

# Размер чанка записи (мс). Меньше = быстрее реакция, но больше нагрузка
CHUNK_MS=100

# Порог определения голоса (RMS). Ниже = чувствительнее к тихому голосу
VAD_THRESHOLD=200.0

# Сколько тишины считать концом фразы (мс). Больше = длиннее паузы допустимы
SILENCE_LIMIT_MS=1800

# ── TTS (синтез речи) ────────────────────────────────────────────────────
# Провайдер синтеза: google | piper | vosk | auto
#   google — онлайн, голос Google (основной, нужен интернет)
#   piper  — офлайн, локальная модель Piper (голос Ирины, 60 МБ)
#   vosk   — офлайн, локальная модель Vosk TTS (5 спикеров, 135 МБ)
#   auto   — piper основной, google резерв
TTS_PROVIDER=google

# Размер LRU-кэша динамических фраз (только для cloud-провайдера)
TTS_CACHE_SIZE=50

# ── Модели (папка models/ рядом с exe) ────────────────────────────────────
# Имена файлов/папок моделей. Можно поменять на другую версию —
# положить новый файл в models/{provider}/ и изменить здесь.
PIPER_MODEL=ru_RU-irina-medium.onnx
VOSK_STT_MODEL=vosk-model-small-ru-0.22
VOSK_TTS_MODEL=vosk-model-tts-ru-0.7-multi

# Спикер Vosk TTS (0-4). 2 = Ирина (женский)
VOSK_TTS_SPEAKER=2

# ── Погода ───────────────────────────────────────────────────────────────
# Город по умолчанию
WEATHER_DEFAULT_CITY=Костюковка

# Ключ OpenWeather API (https://openweathermap.org/api)
# Пусто = используется Open-Meteo (бесплатно, без регистрации)
OPENWEATHER_API_KEY=

# ── YouTube ─────────────────────────────────────────────────────────────
# Количество результатов поиска
YOUTUBE_SEARCH_LIMIT=10